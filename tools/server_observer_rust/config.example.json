{
  "_comment": "Example configuration for server_observer_rust",
  "_comment_usage": "Copy to config.json and fill in real values",
  "WEBSHARE_API_TOKEN": "your-webshare-api-token",
  "metrics_port": 9090,
  "max_parallel_recordings": 5,
  "max_parallel_updates": 3,
  "max_parallel_first_updates": 2,
  "update_interval": 60.0,
  "output_dir": "./recordings",
  "output_metadata_dir": "./recordings/metadata",
  "registry_path": "./recordings/metadata/server_observer_registry.json",
  "long_term_storage_path": "./long_term_storage",
  "file_size_threshold": 104857600,
  "scenario_ids": [
    3328,
    3332
  ],
  "scan_interval": 300.0,
  "enabled_scanning": true,
  "max_guest_games_per_account": -1,
  "listing_account": {
    "username": "listing_account_username",
    "password": "listing_account_password",
    "proxy_url": "socks5://proxy-user:proxy-pass@proxy-host:1080"
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "database": "conflict_replays",
    "user": "postgres",
    "password": "postgres"
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "stream_name": "game_responses",
    "password": null
  },
  "storage": {
    "static_maps_dir": "./recordings/static_maps",
    "s3": {
      "endpoint_url": "https://your-s3-endpoint.example.com",
      "access_key": "your-access-key",
      "secret_key": "your-secret-key",
      "bucket_name": "replays",
      "region": "us-east-1"
    }
  }
}
