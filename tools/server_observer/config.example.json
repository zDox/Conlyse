{
  "COMMENT": "Example configuration for ServerObserver - Copy to config.json and customize",
  "WEBSHARE_API_TOKEN": "",
  "observation_settings": {
    "max_concurrent_observations": 5,
    "observation_interval_seconds": 60
  },
  "storage": {
    "recordings_dir": "/app/recordings",
    "long_term_storage_dir": "/app/long_term_storage",
    "static_maps_dir": "/app/static_maps",
    "s3_enabled": false,
    "s3": {
      "endpoint_url": "https://your-hetzner-s3-endpoint.com",
      "access_key": "your-access-key",
      "secret_key": "your-secret-key",
      "bucket_name": "replays",
      "region": "us-east-1"
    }
  },
  "database": {
    "enabled": false,
    "host": "localhost",
    "port": 5432,
    "database": "conflict_replays",
    "user": "postgres",
    "password": "password"
  },
  "proxy": {
    "http": "",
    "https": ""
  },
  "redis": {
    "host": "localhost",
    "port": 6379,
    "stream_name": "game_responses"
  }
}
