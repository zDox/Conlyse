{
  "_comment": "Example configuration for ServerObserver with separate metadata and response directories",
  
  "scenario_ids": [123, 456, 789],
  
  "max_parallel_recordings": 5,
  "max_parallel_updates": 10,
  "max_parallel_first_updates": 3,
  
  "scan_interval": 30,
  "update_interval": 60,
  
  "output_dir": "./output_responses",
  "output_metadata_dir": "./output_metadata",
  
  "enabled_scanning": true,
  
  "account_pool_path": "./accounts.json",
  
  "_output_structure": {
    "_comment": "With the configuration above, files will be organized as follows:",
    "responses": [
      "output_responses/game_12345/responses.jsonl.zst",
      "output_responses/game_12345/requests.jsonl.zst",
      "output_responses/game_12345/game_states.bin",
      "output_responses/game_12345/static_map_data.bin"
    ],
    "metadata": [
      "output_metadata/game_12345/metadata.json",
      "output_metadata/game_12345/recording.log",
      "output_metadata/server_observer_registry.json"
    ]
  },
  
  "_backward_compatibility": {
    "_comment": "If output_metadata_dir is not specified, all files will be in output_dir (default behavior)",
    "example": {
      "output_dir": "./recordings",
      "_structure": [
        "recordings/game_12345/responses.jsonl.zst",
        "recordings/game_12345/metadata.json",
        "recordings/game_12345/recording.log",
        "recordings/server_observer_registry.json"
      ]
    }
  }
}
