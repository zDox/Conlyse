# PostgreSQL Configuration
POSTGRES_DB=replays
POSTGRES_USER=converter
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Redis Configuration
REDIS_PORT=6379

# MinIO (S3) Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=replays
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Conlyse API Configuration
API_PORT=8000
JWT_SECRET_KEY=change-me-in-production

# CORS: comma-separated list of allowed origins for the web client
# e.g. CORS_ALLOW_ORIGINS=https://app.conlyse.com,http://localhost:3000
CORS_ALLOW_ORIGINS=

# Rate limiting (limits library syntax)
RATE_LIMIT_ANONYMOUS=10/minute
RATE_LIMIT_AUTHENTICATED=60/minute

# Email verification on registration (set to true to require email verification)
EMAIL_VERIFICATION_ENABLED=false
EMAIL_VERIFICATION_CODE_EXPIRE_SECONDS=3600

# SMTP (used for 2FA codes and email verification)
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@conlyse.com
SMTP_TLS=true
